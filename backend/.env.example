# ============================================================
# SIGMA Backend — Variables d'environnement
# ============================================================
# Copier ce fichier vers `.env` et adapter les valeurs.
# Ne jamais committer le fichier `.env` en production !
# ============================================================

# --- Application ---
APP_NAME="SIGMA API"
APP_VERSION="1.0.0"
DEBUG=true
# ENVIRONMENT contrôle le comportement de l'application :
#   development : logs OTP en clair, create_all SQLAlchemy automatique au boot
#   production  : OTP masqué, démarrage bloqué si JWT_SECRET_KEY est la valeur par défaut
ENVIRONMENT="development"

# --- Base de données PostgreSQL ---
# Format : postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL="postgresql+asyncpg://sigma_user:sigma_pass@localhost:5432/sigma_db"

# --- Redis ---
# Format : redis://<host>:<port>/<db_index>
REDIS_URL="redis://localhost:6379/0"

# --- JWT ---
# ⚠️  CRITIQUE : Utiliser une valeur aléatoire longue et secrète en production.
# Générer avec : python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY="change-me-in-production-use-a-long-random-string-min-64-chars"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OTP ---
OTP_EXPIRE_SECONDS=300
OTP_LENGTH=6

# --- Token d'inscription temporaire ---
REGISTRATION_TOKEN_EXPIRE_MINUTES=15
